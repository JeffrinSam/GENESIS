# GENESIS Environment Configuration
# Copy this file to .env and fill in your values
# Usage: export $(cat .env | xargs) before running scripts

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (needed for Part 1 ClaudeOpusBrain with --model opus/sonnet)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Flask secret key for the web UIs (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# ── Model paths (upstream repos — clone separately per docs/SETUP.md) ─────────

# WAN 2.2 video generation model root
WAN_ROOT=/path/to/Wan2.2

# Cosmos Predict 2.5 root
COSMOS_ROOT=/path/to/cosmos-predict2.5

# Cosmos Reason 2 root
COSMOS_REASON2_ROOT=/path/to/cosmos-reason2

# Qwen3-VL prompt extenders root (defaults to part1_generation/qwen_prompt_expansion/)
QWEN_ROOT=/path/to/Qwen3-VL

# Path to the Qwen3-VL model weights (or HuggingFace model ID like Qwen/Qwen3.5-9B)
QWEN_MODEL_PATH=/path/to/Qwen3.5-9B

# ── Optional: alternative optimizer backend ────────────────────────────────────

# Ollama server for open-source LLM optimizer (Llama, Qwen)
# Default: http://localhost:11434
OLLAMA_SERVER=http://localhost:11434

# LTX-Video server for trajectory interpolation (simulator utilities only)
LTX_SERVER=http://localhost:5001

# ── Simulation (Part 3 — Isaac Sim required) ──────────────────────────────────

# Path to Isaac Sim python launcher
# Example: /home/user/isaacsim/python.sh
ISAAC_SIM_PYTHON=/path/to/isaacsim/python.sh

# Unitree G1 WBC / Digitaltwin models directory
DIGITALTWIN_DIR=/path/to/Digitaltwin

# IsaacLab-Arena repo path
ISAACLAB_ARENA_DIR=/path/to/IsaacLab-Arena
